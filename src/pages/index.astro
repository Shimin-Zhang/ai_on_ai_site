---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import ThePrompt from '../components/ThePrompt.astro';
import Leaderboard from '../components/Leaderboard.astro';
import Verdict from '../components/Verdict.astro';
import PersonalityCards from '../components/PersonalityCards.astro';
import DelusionIndex from '../components/DelusionIndex.astro';
import BeatTheAIs from '../components/BeatTheAIs.astro';
import ScoreHeatmap from '../components/ScoreHeatmap.astro';
import IdentificationMatrix from '../components/IdentificationMatrix.astro';
import EvaluatorDeepDive from '../components/EvaluatorDeepDive.astro';
import RawOutputExplorer from '../components/RawOutputExplorer.astro';
import Methodology from '../components/Methodology.astro';
import Limitations from '../components/Limitations.astro';
import Footer from '../components/Footer.astro';
import TopNav from '../components/TopNav.astro';

const title = "AIonAI Arena — 11 LLMs predict AI's impact, graded each other blind";
const description = "11 LLMs predict how AI changes the world, then graded against each other blind. They mostly missed themselves.";
const canonical = Astro.site?.toString() ?? '';
const ogImage = new URL('/og.png', Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      try {
        if (localStorage.getItem('aionai-theme') === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      } catch (e) {}
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AIonAI Arena" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="AIonAI Arena — 11 LLMs predicted how AI changes the world, graded each other blind, and mostly missed themselves." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-term-bg text-term-fg font-mono">
    <TopNav />
    <main class="px-4 md:px-6">
      <Hero />
      <ThePrompt />
      <Leaderboard />
      <Verdict />
      <PersonalityCards />
      <DelusionIndex />
      <BeatTheAIs />
      <ScoreHeatmap />
      <IdentificationMatrix />
      <EvaluatorDeepDive />
      <RawOutputExplorer />
      <Methodology />
      <Limitations />
      <Footer />
    </main>
  </body>
</html>
