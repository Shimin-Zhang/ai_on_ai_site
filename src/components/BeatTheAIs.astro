---
// src/components/BeatTheAIs.astro
import puzzleSnippets from '../data/puzzle-snippets.json';
import models from '../data/models.json';
import type { Model } from '../lib/types';
import SectionHeader from '../lib/SectionHeader.astro';

const choices = (models as Model[]).map((m) => ({ letter: m.letter, displayName: m.displayName }));
---
<section id="beat-the-ais" class="py-16 md:py-20">
  <div class="wrap-data">
    <SectionHeader num="06" title="BEAT_THE_AIS">5 snippets · best AI: 45% · median AI: 18% · random: ~9%</SectionHeader>

    <div
      id="puzzle-root"
      data-snippets={JSON.stringify(puzzleSnippets)}
      data-choices={JSON.stringify(choices)}
      data-identifications={JSON.stringify(Object.fromEntries((models as Model[]).map((m) => [m.letter, m.timesCorrectlyIdentified])))}
    >
      <div id="puzzle-board" class="bg-term-surface/60 border border-term-border rounded-md p-4 md:p-6">
        <p class="text-term-dim text-xs">// loading puzzle...</p>
      </div>
    </div>
  </div>
</section>

<script src="../scripts/beat-the-ais-ui.ts"></script>
