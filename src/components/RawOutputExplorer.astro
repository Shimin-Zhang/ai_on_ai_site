---
import models from '../data/models.json';
import { marked } from 'marked';
import type { Model } from '../lib/types';
import SectionHeader from '../lib/SectionHeader.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

interface Turn {
  user: string;
  reasoning: string | null;
  assistant: string;
}

const TURN_BORDER = ['border-term-green', 'border-term-yellow', 'border-term-red'];

const sorted = (models as Model[]).slice().sort((a, b) => a.rank - b.rank);
const outputs = sorted.map((m) => {
  const transcript = JSON.parse(readFileSync(join(process.cwd(), 'src/data/outputs', `${m.letter}.json`), 'utf-8')) as { turns: Turn[] };
  return {
    letter: m.letter,
    displayName: m.displayName,
    turns: transcript.turns.map((t) => ({
      user: t.user,
      reasoningHtml: t.reasoning ? marked.parse(t.reasoning) : null,
      assistantHtml: marked.parse(t.assistant),
    })),
  };
});
---
<section id="explorer" class="py-16 md:py-20">
  <div class="wrap-data">
    <SectionHeader num="10" title="RAW_OUTPUT_EXPLORER">pick a model · full three-turn transcript</SectionHeader>

    <div class="flex flex-wrap items-center gap-4 mb-8 p-3 rounded-md border border-term-border bg-term-surface/40">
      <label class="text-term-dim text-[11px] tracking-wider">MODEL</label>
      <select id="output-select" class="bg-term-bg border border-term-border rounded px-3 py-1.5 text-term-fg text-sm hover:border-term-dim focus:border-term-green outline-none">
        {sorted.map((m) => <option value={m.letter}>[{m.letter}] {m.displayName} (#{m.rank})</option>)}
      </select>
      <label class="text-term-dim text-sm flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" id="output-reasoning" class="accent-term-green" />
        <span>show reasoning traces</span>
      </label>
    </div>

    <div id="output-bodies" class="wrap-read">
      {outputs.map((o) => (
        <article data-letter={o.letter} class="output-body hidden space-y-10">
          {o.turns.map((t, i) => (
            <div class="turn">
              <p class="text-term-green text-[11px] tracking-wider mb-2">&gt; turn {i + 1} · user</p>
              <blockquote class={`border-l-2 ${TURN_BORDER[i] ?? 'border-term-green'} pl-4 md:pl-6 text-sm md:text-base leading-relaxed text-term-fg italic whitespace-pre-wrap`}>
                {t.user}
              </blockquote>

              {t.reasoningHtml && (
                <div class="reasoning-block hidden mt-4">
                  <div class="output-clamp p-4 bg-term-surface border border-term-border rounded relative overflow-hidden">
                    <p class="text-term-green text-[11px] tracking-wider mb-2">// REASONING — turn {i + 1}</p>
                    <div class="prose prose-invert prose-sm max-w-none text-term-dim" set:html={t.reasoningHtml}></div>
                    <div class="output-fade absolute inset-x-0 bottom-0 h-16 pointer-events-none"
                         style="background: linear-gradient(to top, var(--term-surface), transparent);"></div>
                  </div>
                  <button class="output-expand mt-2 text-term-green text-sm hover:underline cursor-pointer">expand reasoning ↓</button>
                </div>
              )}

              <div class="mt-4">
                <p class="text-term-dim text-[11px] tracking-wider mb-2">// assistant — turn {i + 1}</p>
                <div class="output-clamp relative overflow-hidden">
                  <div class="prose prose-invert prose-sm max-w-none text-term-fg" set:html={t.assistantHtml}></div>
                  <div class="output-fade absolute inset-x-0 bottom-0 h-20 pointer-events-none"
                       style="background: linear-gradient(to top, var(--term-bg), transparent);"></div>
                </div>
                <button class="output-expand mt-3 text-term-green text-sm hover:underline cursor-pointer">expand answer ↓</button>
              </div>
            </div>
          ))}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .output-clamp { max-height: 18rem; }
  .turn.expanded .output-clamp,
  .reasoning-block.expanded .output-clamp,
  .turn > div.expanded .output-clamp { max-height: none; }
  .turn.expanded > div > .output-fade,
  .reasoning-block.expanded .output-fade,
  .turn > div.expanded .output-fade { display: none; }
  .expanded > .output-expand { display: none; }
</style>

<script src="../scripts/raw-explorer.ts"></script>
