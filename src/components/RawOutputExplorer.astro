---
// src/components/RawOutputExplorer.astro
import models from '../data/models.json';
import { marked } from 'marked';
import type { Model } from '../lib/types';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const sorted = (models as Model[]).slice().sort((a, b) => a.rank - b.rank);
const outputs = sorted.map((m) => {
  const raw = JSON.parse(readFileSync(join(process.cwd(), 'src/data/outputs', `${m.letter}.json`), 'utf-8')) as { reasoning: string | null; answer: string };
  return {
    letter: m.letter,
    displayName: m.displayName,
    reasoningHtml: raw.reasoning ? marked.parse(raw.reasoning) : null,
    answerHtml: marked.parse(raw.answer),
  };
});
---
<section id="explorer" class="py-12 border-b border-term-border">
  <p class="text-term-green text-sm mb-2">## RAW_OUTPUT_EXPLORER</p>
  <p class="text-term-dim text-xs mb-4">// pick a model. read what it actually wrote.</p>

  <div class="flex flex-wrap items-center gap-3 mb-4">
    <label class="text-term-dim text-sm">MODEL:</label>
    <select id="output-select" class="bg-term-surface border border-term-border rounded px-2 py-1 text-term-fg">
      {sorted.map((m) => <option value={m.letter}>[{m.letter}] {m.displayName} (#{m.rank})</option>)}
    </select>
    <label class="text-term-dim text-sm flex items-center gap-2">
      <input type="checkbox" id="output-reasoning" />
      show reasoning trace
    </label>
  </div>

  <div id="output-bodies">
    {outputs.map((o) => (
      <article data-letter={o.letter} class="output-body hidden">
        {o.reasoningHtml && (
          <div class="reasoning-block hidden mb-6 p-4 bg-term-surface border border-term-border rounded">
            <p class="text-term-green text-xs mb-2">// REASONING TRACE</p>
            <div class="prose prose-invert prose-sm max-w-none text-term-dim" set:html={o.reasoningHtml}></div>
          </div>
        )}
        <div class="prose prose-invert prose-sm max-w-none text-term-fg" set:html={o.answerHtml}></div>
      </article>
    ))}
  </div>
</section>

<script>
  // npm install marked is required by this component.
</script>

<script src="../scripts/raw-explorer.ts"></script>
