---
// src/components/EvaluatorDeepDive.astro
import evaluators from '../data/evaluators.json';
import type { Evaluator } from '../lib/types';
import SectionHeader from '../lib/SectionHeader.astro';
const sorted = (evaluators as Evaluator[]).slice().sort((a, b) => a.sharpnessRank - b.sharpnessRank);
---
<section id="evaluators" class="py-16 md:py-20">
  <div class="wrap-data">
    <SectionHeader num="09" title="EVALUATORS_RANKED">who could tell models apart · range = lowest score given → highest</SectionHeader>

    <div class="overflow-x-auto rounded-md border border-term-border bg-term-surface/40">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-term-dim text-left text-[11px] tracking-wider uppercase border-b border-term-border">
            <th class="py-2.5 px-3 w-10">#</th>
            <th class="py-2.5 px-2">evaluator</th>
            <th class="py-2.5 px-3 text-right tabular-nums">correct</th>
            <th class="py-2.5 px-3 w-[26%]">accuracy</th>
            <th class="py-2.5 px-3 text-right tabular-nums">score range</th>
            <th class="py-2.5 px-3 w-[22%]">spread</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map((e) => {
            const isTop = e.sharpnessRank === 1;
            const isBottom = e.accuracyPct === 0;
            const accWidth = (e.correctIds / 11) * 100;
            const spread = e.scoreRange[1] - e.scoreRange[0];
            const spreadWidth = (spread / 13) * 100; // 13 = rough max spread
            return (
              <tr class={`border-b border-term-border/50 last:border-b-0 ${isTop ? 'bg-term-surface/50' : ''}`}>
                <td class={`py-2.5 px-3 tabular-nums ${isTop ? 'text-term-green font-medium' : 'text-term-dim'}`}>{e.sharpnessRank}</td>
                <td class="py-2.5 px-2">
                  <span class="text-term-dim">[{e.letter}]</span> <span class="text-term-fg">{e.displayName}</span>
                </td>
                <td class={`py-2.5 px-3 text-right tabular-nums ${isBottom ? 'text-term-red' : 'text-term-yellow'}`}>{e.correctIds}/11</td>
                <td class="py-2.5 px-3">
                  <div class="flex items-center gap-2">
                    <div class="h-1.5 bg-term-border/60 rounded-sm overflow-hidden flex-1">
                      <div class={`h-full ${isTop ? 'bg-term-green' : isBottom ? 'bg-term-red/70' : 'bg-term-dim'}`} style={`width: ${Math.max(accWidth, 2)}%`}></div>
                    </div>
                    <span class="text-term-dim text-[11px] tabular-nums w-8 text-right">{e.accuracyPct}%</span>
                  </div>
                </td>
                <td class="py-2.5 px-3 text-right text-term-dim tabular-nums">{e.scoreRange[0]}–{e.scoreRange[1]}</td>
                <td class="py-2.5 px-3">
                  <div class="h-1.5 bg-term-border/60 rounded-sm overflow-hidden">
                    <div class="h-full bg-term-yellow/60" style={`width: ${Math.max(spreadWidth, 2)}%`}></div>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <p class="mt-3 text-term-dim text-xs max-w-[72ch]">
      // The best AI evaluator (Opus 4.7) hit 45%. The worst (Gemini Flash, MiniMax) got nothing right and gave 9 of 11 models a 29 — narrow spread, no signal.
    </p>
  </div>
</section>
