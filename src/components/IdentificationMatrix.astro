---
// src/components/IdentificationMatrix.astro
import models from '../data/models.json';
import guesses from '../data/guesses.json';
import type { Model, GuessMatrix, Letter } from '../lib/types';
import SectionHeader from '../lib/SectionHeader.astro';

const rankedLetters: Letter[] = (models as Model[]).slice().sort((a, b) => a.rank - b.rank).map((m) => m.letter);
const evaluatorOrder: Letter[] = rankedLetters;
const subjectOrder: Letter[] = rankedLetters;
const modelByLetter = Object.fromEntries((models as Model[]).map((m) => [m.letter, m]));
---
<section id="id-matrix" class="py-16 md:py-20">
  <div class="wrap-data">
    <SectionHeader num="08" title="IDENTIFICATION_MATRIX">
      rows = guesser · cols = subject · <span class="text-term-green">green</span> = correct · dash = no guess
    </SectionHeader>

    <div class="rounded-md border border-term-border bg-term-surface/40 p-4 md:p-6">
      <div class="overflow-x-auto">
        <table class="border-collapse text-xs">
          <thead>
            <tr>
              <th class="p-1"></th>
              {subjectOrder.map((s) => (
                <th class="p-1 text-term-dim font-normal text-center" title={modelByLetter[s].displayName}>[{s}]</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {evaluatorOrder.map((ev) => (
              <tr>
                <th class="p-1 pr-3 text-term-dim font-normal text-right whitespace-nowrap text-[11px]" title={modelByLetter[ev].displayName}>
                  [{ev}] <span class="text-term-fg">{modelByLetter[ev].displayName}</span>
                </th>
                {subjectOrder.map((sub) => {
                  const guess = (guesses as GuessMatrix)[ev]?.[sub];
                  const correct = guess?.correct ?? false;
                  const empty = !guess || guess.text === '—';
                  return (
                    <td class="p-[2px]">
                      <div
                        class={`idcell rounded-[2px] px-1.5 py-1 text-center min-w-[68px] cursor-pointer transition-colors
                                ${correct ? 'text-term-green bg-term-green/10 border border-term-green/60'
                                         : empty ? 'text-term-dim/60 border border-term-border'
                                         : 'text-term-fg border border-term-border hover:border-term-dim'}`}
                        data-evaluator={ev}
                        data-subject={sub}
                        data-guess={guess?.text ?? '—'}
                        data-correct={correct ? '1' : '0'}
                      >{guess?.text ?? '—'}</div>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="id-tooltip" class="hidden fixed z-50 max-w-xs bg-term-surface border border-term-green rounded p-3 text-xs shadow-xl pointer-events-none"></div>
</section>

<script src="../scripts/id-matrix.ts"></script>
