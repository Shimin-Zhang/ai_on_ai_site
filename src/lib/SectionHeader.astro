---
interface Props {
  num?: string;
  title: string;
}
const { num, title } = Astro.props;
---
<header class="section-hd mb-6">
  <div>
    {num && <p class="section-num">{num}</p>}
    <p class={`section-title ${num ? 'mt-1' : ''}`}>## {title}</p>
  </div>
  <p class="section-meta"><slot /></p>
</header>
