---
// src/lib/Pill.astro
import type { Letter } from './types.js';

interface Props {
  letter: Letter;
  label?: string;
}
const { letter, label } = Astro.props;
---
<a
  href={`#card-${letter}`}
  class="inline-block px-1.5 py-0.5 mx-0.5 rounded border border-term-border bg-term-surface text-term-green text-xs font-mono hover:bg-term-border transition-colors"
>
  [{letter}]{label ? ` ${label}` : ''}
</a>
